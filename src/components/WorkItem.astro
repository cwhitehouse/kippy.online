---
import HoverImage from './HoverImage';

interface Props {
  title: string;
  dates: string;
  description: string;
  tech: string;
  color: string;
  image: {
    src: string;
    webp?: string;
    altSrc?: string;
    alt: string;
  };
  flip: boolean;
}

const { title, dates, description, tech, color, image, flip } = Astro.props;

const imgClass = flip ? 'col-start-1 col-end-6' : 'col-start-7 col-end-12';
const contentClass = flip ? 'col-start-7 col-end-12' : 'col-start-1 col-end-6';
---

<div class="lg:grid grid-cols-12 col-span-12 items-center">
  <div class={imgClass}>
    <HoverImage
      src={image.src}
      webp={image.webp}
      altSrc={image.altSrc}
      alt={image.alt}
      client:visible
    />
  </div>
  <div class={`${contentClass} row-start-1 mt-8 lg:mt-0`}>
    <h2 class="font-semibold font-serif text-3xl lg:text-4xl">{title}</h2>
    <p class="font-mono text-xs lg:text-sm text-gray-600 dark:text-gray-300 mt-2">
      {dates}
    </p>
    <div class={`h-1 w-12 lg:w-20 mt-3 ${color}`}></div>
    <p class="mt-4 text-lg lg:text-2xl">{description}</p>
    <p class="font-mono text-sm lg:text-base text-gray-600 dark:text-gray-300 mt-4">
      {tech}
    </p>
  </div>
</div>
