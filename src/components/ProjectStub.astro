---
import VivereDemo from './VivereDemo.astro';
import GitHub from './icons/GitHub.astro';
import Npm from './icons/Npm.astro';
import Web from './icons/Web.astro';

const { title, description, tech, image, github, npm, website, idx } = Astro.props;
const wrapperClass = idx % 2 !== 0 ? 'col-start-7' : '';
---
<div class={`col-span-5 ${wrapperClass}`}>
  <div class="h-64">
    {image ? (
      <div class="h-full w-full border-2 rounded-t-lg bg-white dark:bg-gray-900 object-cover flex items-center justify-center p-4 overflow-hidden">
        <img src={image.src.light} alt={image.alt} v-if="!darkMode" />
        <img src={image.src.dark} alt={image.alt} v-if="darkMode" hidden />
      </div>
    ) : (
      <VivereDemo />
    )}
  </div>
  <p class="font-semibold font-serif text-3xl lg:text-4xl mt-8">{title}</p>
  <p class="text-lg lg:text-2xl mt-4">{description}</p>
  <p class="font-mono text-sm text-gray-600 dark:text-gray-300 mt-4">{tech}</p>
  <div class="flex items-center mt-4 space-x-4">
    {github && (
      <a class="icon-link-blue py-1" href={github} aria-label="Link to GitHub">
        <GitHub size={24} />
      </a>
    )}
    {npm && (
      <a class="icon-link-blue" href={npm} aria-label="Link to npm">
        <Npm size={32} />
      </a>
    )}
    {website && (
      <a class="icon-link-blue py-1" href={website} aria-label="Link to Website">
        <Web size={24} />
      </a>
    )}
  </div>
</div>
